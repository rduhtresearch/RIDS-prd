# RIDS runtime configuration. Copy to .env for docker compose, or export
# these variables in any hosting environment. Never commit .env.

# --- Required ---------------------------------------------------------------
# Encryption key for stored secrets (user API credentials, TOTP secrets).
# 16+ characters. Generate with: openssl rand -hex 32
RIDS_CREDENTIAL_SECRET=

# --- Storage ----------------------------------------------------------------
# "postgres" (hosted / docker compose default) or "duckdb" (single-file dev)
RIDS_STORAGE_MODE=postgres

# postgres mode: full connection URL (Supabase: use the connection string
# from Project Settings -> Database, sslmode=require). Alternatively set the
# standard PG* variables (PGHOST, PGPORT, PGDATABASE, PGUSER, PGPASSWORD).
RIDS_DATABASE_URL=postgres://rids:rids-dev-password@db:5432/rids

# duckdb mode: path to the database file
#RIDS_DB_DIR=/app/data/RIDS.duckdb

# Local docker compose Postgres password (dev only)
POSTGRES_PASSWORD=rids-dev-password

# --- App --------------------------------------------------------------------
# dev | test | live  (live enables clean-shutdown-when-idle behavior)
RIDS_APP_STATUS=dev
RIDS_APP_PORT=3838
RIDS_AUTH_SESSION_HOURS=10

# File locations (defaults inside the container; mount volumes over them)
#RIDS_ICT_UPLOAD_DIR=/app/uploads
#RIDS_EDGE_OUTPUT_DIR=/app/outputs
#RIDS_APP_LOG_DIR=/app/logs

# Version labels shown in the UI
#RIDS_APP_VERSION=v2.0.0
#RIDS_APP_LAST_UPDATED=2026-07-06
