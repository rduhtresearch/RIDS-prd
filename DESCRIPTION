    duckdb (>= 1.5.4),
    sodium (>= 1.4.0),
    shiny (>= 1.14.0),
    bs4Dash (>= 2.3.5),
    waiter (>= 0.2.5),
    shinyFeedback (>= 0.4.0),
    shinyjs (>= 2.1.1),
    reactable (>= 0.4.5),
    DT (>= 0.34.0),
